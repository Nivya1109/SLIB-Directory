generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Library {
  id             String             @id @default(cuid())
  name           String             @unique
  slug           String             @unique
  shortSummary   String?
  description    String?
  functionDesc   String?
  socialImpact   String?
  exampleCode    String?
  officialUrl    String?
  repositoryUrl  String?
  costMinUSD     Int?
  costMaxUSD     Int?
  developerId    String?
  organizationId String?
  scrapedAt      DateTime?
  dataSource     String?
  tags           String[]           @default([])
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  features       Feature[]
  developer      Developer?         @relation(fields: [developerId], references: [id])
  organization   Organization?      @relation(fields: [organizationId], references: [id])
  dependents     LibraryDep[]       @relation("LibraryDependents")
  dependsOn      LibraryDep[]       @relation("LibraryDependencies")
  categories     Library_Category[]
  languages      Library_Language[]
  platforms      Library_Platform[]
  versions       Version[]

  @@index([slug])
  @@index([developerId])
  @@index([organizationId])
}

model Developer {
  id        String    @id @default(cuid())
  name      String    @unique
  url       String?
  libraries Library[]
}

model Organization {
  id        String    @id @default(cuid())
  name      String    @unique
  url       String?
  libraries Library[]
}

model Category {
  id        String             @id @default(cuid())
  name      String             @unique
  libraries Library_Category[]
}

model Library_Category {
  libraryId  String
  categoryId String
  assignedAt DateTime @default(now())
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  library    Library  @relation(fields: [libraryId], references: [id], onDelete: Cascade)

  @@id([libraryId, categoryId])
  @@index([categoryId])
}

model Platform {
  id        String             @id @default(cuid())
  name      String             @unique
  libraries Library_Platform[]
}

model Library_Platform {
  libraryId  String
  platformId String
  library    Library  @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  platform   Platform @relation(fields: [platformId], references: [id], onDelete: Cascade)

  @@id([libraryId, platformId])
  @@index([platformId])
}

model Language {
  id        String             @id @default(cuid())
  name      String             @unique
  libraries Library_Language[]
}

model Library_Language {
  libraryId  String
  languageId String
  language   Language @relation(fields: [languageId], references: [id], onDelete: Cascade)
  library    Library  @relation(fields: [libraryId], references: [id], onDelete: Cascade)

  @@id([libraryId, languageId])
  @@index([languageId])
}

model Version {
  id         String    @id @default(cuid())
  libraryId  String
  name       String
  releasedAt DateTime?
  notes      String?
  library    Library   @relation(fields: [libraryId], references: [id], onDelete: Cascade)

  @@index([libraryId])
}

model Feature {
  id        String  @id @default(cuid())
  libraryId String
  name      String
  spec      String?
  required  Boolean @default(true)
  library   Library @relation(fields: [libraryId], references: [id], onDelete: Cascade)

  @@index([libraryId])
}

model LibraryDep {
  id          String  @id @default(cuid())
  libraryId   String
  dependsOnId String
  dependsOn   Library @relation("LibraryDependents", fields: [dependsOnId], references: [id], onDelete: Cascade)
  library     Library @relation("LibraryDependencies", fields: [libraryId], references: [id], onDelete: Cascade)

  @@unique([libraryId, dependsOnId])
  @@index([dependsOnId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("user")
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SupportTicket {
  id         String    @id @default(cuid())
  name       String
  email      String
  subject    String
  category   String
  message    String
  status     String    @default("open")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  adminReply String?
  repliedAt  DateTime?

  @@index([status])
  @@index([createdAt])
}
